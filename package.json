{
  "name": "fieldshield",
  "version": "1.1.3",
  "description": "Sensitive input protection for React — prevents DOM scraping, clipboard exfiltration, and accidental PHI exposure in healthcare and fintech applications.",
  "type": "module",
  "license": "MIT",
  "author": "Anurag Nedunuri",
  "homepage": "https://fieldshield-demo.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anuragnedunuri/fieldshield.git"
  },
  "bugs": {
    "url": "https://github.com/anuragnedunuri/fieldshield/issues"
  },
  "keywords": [
    "react",
    "security",
    "input",
    "pii",
    "phi",
    "hipaa",
    "pci-dss",
    "clipboard",
    "web-worker",
    "sensitive-data",
    "healthcare",
    "fintech",
    "dom-security",
    "data-protection"
  ],
  "files": [
    "dist/assets",
    "dist/components",
    "dist/hooks",
    "dist/utils",
    "dist/fieldshield.js",
    "dist/fieldshield.umd.cjs",
    "dist/index.d.ts",
    "dist/index.d.cts",
    "dist/style.d.ts",
    "dist/patterns.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THREAT_MODEL.md"
  ],
  "main": "./dist/fieldshield.umd.cjs",
  "module": "./dist/fieldshield.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/fieldshield.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/fieldshield.umd.cjs"
      }
    },
    "./style": {
      "types": "./dist/style.d.ts",
      "default": "./dist/assets/fieldshield.css"
    },
    "./dist/assets/fieldshield.css": "./dist/assets/fieldshield.css"
  },
  "sideEffects": [
    "./dist/assets/fieldshield.css"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --mode lib && tsc -p tsconfig.lib.json && node -e \"require('fs').copyFileSync('dist/index.d.ts','dist/index.d.cts')\" && node -e \"require('fs').writeFileSync('dist/style.d.ts','// Side-effect import — no exports.\\ndeclare const _: undefined;\\nexport default _;\\n')\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build:lib"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0"
  }
}
